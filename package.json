    "@angular/router": "^21.2.7",
    "get-my-photo": "file:projects/get-my-photo",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
